{
  "name": "family-jukebox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:staging": "NEXT_PUBLIC_APP_ENV=staging NEXT_PUBLIC_SITE_URL=http://localhost:3000 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "smoke": "tsx --test scripts/smoke.test.ts",
    "smoke:production": "node scripts/production-smoke.mjs",
    "ci": "npm run lint && npm run smoke && npm run build && npm run smoke:production",
    "db:generate": "drizzle-kit generate",
    "db:push": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@neondatabase/serverless": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "puppeteer": "^24.36.1"
  }
}
